{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "CRBRVS_Website": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "defaultConfiguration": "production",
          "builder": "@angular/build:application",
          "options": {
            "optimization": {
              "styles": true,
              "fonts": true
            },
            "aot": true,
            "sourceMap": false,
            "namedChunks": false,
            "outputPath": "dist/crbrvs-website",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              "src/robots.txt",
              "src/sitemap.xml",
              "src/google829ea8c08fad9b84.html"
            ],
            "styles": [
              "./node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "./src/bootstrap-essentials.css",
              "./src/styles.css"
            ],
            "scripts": [],
            "server": "src/main.server.ts",
            "prerender": true,
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "baseHref": "/",
              "optimization": {
                "scripts": true,
                "styles": true,
                "fonts": true
              },
              "outputHashing": "all",
              "sourceMap": false,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kb",
                  "maximumError": "8kb"
                }
              ],
              "subresourceIntegrity": true
            },
            "development": {
              "baseHref": "/",
              "optimization": {
                "scripts": true,
                "styles": true,
                "fonts": true
              },
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "CRBRVS_Website:build:production"
            },
            "development": {
              "buildTarget": "CRBRVS_Website:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "CRBRVS_Website:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "de1f852a-bd70-4a06-af06-5ac37d25e8d4"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
